# Database Configuration
# PostgreSQL Database Connection
DATABASE_URL=postgresql://username:password@localhost:5432/mosi_media_db

# Alternative: MySQL Database Connection
# DATABASE_URL=mysql://username:password@localhost:3306/mosi_media_db

# Database Configuration Options
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mosi_media_db
DB_USER=your_username
DB_PASSWORD=your_password
DB_SSL=false

# JWT Secret for authentication (if needed)
JWT_SECRET=your-super-secret-jwt-key-here

# API Configuration
API_BASE_URL=http://localhost:3001/api
NODE_ENV=development

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,mp4,mov,pdf

# Email Configuration (for contact forms)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@mosimediasolutions.com

# Redis Configuration (for caching, optional)
REDIS_URL=redis://localhost:6379

# Analytics (optional)
GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
